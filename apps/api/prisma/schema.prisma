// Generator Block: Tells Prisma to generate the TypeScript client
generator client {
  provider      = "prisma-client-js"
  // binaryTargets are needed for cross-platform compatibility
  // "native" runs on local machine (Mac/Windows)
  // "linux-musl-openssl-3.0.x" runs inside the Docker container (Alpine Linux)
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

// Datasource Block: Defines the connection to the database
datasource db {
  provider = "postgresql"
  // This uses the DATABASE_URL environment variable from .env file
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("user")

  products  Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @default("No description available")
  price       Float
  category    String
  image       String

  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}